NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/transitops
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:8080

# Whapi WhatsApp (driver notifications only)
# Get token: https://whapi.cloud → Dashboard → your channel → API Token
WHAPI_TOKEN=your-whapi-api-token-here
WHAPI_BASE_URL=https://gate.whapi.cloud
WHAPI_ENABLED=false
WHAPI_DEFAULT_COUNTRY_CODE=254
TRIP_REMINDER_MINUTES=30

# Google Gemini AI (incident analyzer + multilingual translation)
# Get a FREE key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
